---
import '@fontsource/jetbrains-mono/500.css';
import '@fontsource/jetbrains-mono/800.css';
import '../styles/global.css';
import Search from '../components/Search.astro';

const {
  title,
  description = 'Free online text and code tools: convert case, clean whitespace, format JSON, encode/decode Base64, hash, diff, generate QR codes, and more. Runs in your browser — nothing is uploaded.',
  robots = 'index,follow',
  ogType = 'website',
} = Astro.props;

// Canonical URL matching the clean URL Cloudflare Pages serves: strip the
// `.html` the 'file' build format adds (otherwise the canonical points at a
// URL that 308-redirects to the clean one), collapse `/index`, and drop any
// trailing slash except root.
let canonicalPath = Astro.url.pathname.replace(/\.html$/, '');
if (canonicalPath.endsWith('/index')) canonicalPath = canonicalPath.slice(0, -'index'.length);
if (canonicalPath !== '/') canonicalPath = canonicalPath.replace(/\/$/, '');
if (canonicalPath === '') canonicalPath = '/';
const canonical = new URL(canonicalPath, Astro.site).href;
const ogImage = new URL('/og.png', Astro.site).href;
const repo = 'https://github.com/MichalAFerber/textwizard';
const year = new Date().getFullYear();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#eef4f6" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0b1220" media="(prefers-color-scheme: dark)" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Michal Ferber" />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="TextWizard" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="TextWizard — free text & code tools that run in your browser" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:creator" content="@michalaferber" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="16x16 32x32 48x48" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <script is:inline>
      // Apply the saved theme before first paint to avoid a flash. With no saved
      // choice we set no attribute and let CSS `prefers-color-scheme` decide.
      (function () {
        try {
          var t = localStorage.getItem('tw::theme');
          if (t === 'dark' || t === 'light')
            document.documentElement.setAttribute('data-theme', t);
        } catch (_) {}
      })();
    </script>

    <slot name="head" />

    <!-- Plausible Analytics — privacy-friendly, cookieless, self-hosted.
         Standard pageview tracking (the site is now multi-page, not hash-routed),
         plus outbound-link, file-download, and tagged-event extensions. -->
    <script
      defer
      data-domain="textwizard.us"
      src="https://plausible.thompsonblack.us/js/script.outbound-links.file-downloads.tagged-events.js"
    ></script>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <header class="site-header">
      <div class="container site-nav">
        <a class="brand" href="/" aria-label="TextWizard home">
          <span class="brand-icon">✨</span>
          <span>TextWizard</span>
        </a>
        <div class="nav-spacer"></div>
        <nav class="nav-links">
          <a class="nav-link" href="/#tools">All tools</a>
          <a class="nav-link" href="/privacy">Privacy</a>
        </nav>
        <button id="search-open" class="icon-btn" type="button" aria-label="Search tools" title="Search tools ( / )">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </button>
        <a class="icon-btn" href={repo} target="_blank" rel="noopener" aria-label="TextWizard on GitHub" title="Source on GitHub">
          <svg viewBox="0 0 16 16" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M8 0c4.42 0 8 3.58 8 8a8.013 8.013 0 0 1-5.45 7.59c-.4.08-.55-.17-.55-.38 0-.27.01-1.13.01-2.2 0-.75-.25-1.23-.54-1.48 1.78-.2 3.65-.88 3.65-3.95 0-.88-.31-1.59-.82-2.15.08-.2.36-1.02-.08-2.12 0 0-.67-.22-2.2.82-.64-.18-1.32-.27-2-.27-.68 0-1.36.09-2 .27-1.53-1.03-2.2-.82-2.2-.82-.44 1.1-.16 1.92-.08 2.12-.51.56-.82 1.27-.82 2.15 0 3.06 1.86 3.75 3.64 3.95-.23.2-.44.55-.51 1.07-.46.21-1.61.55-2.33-.66-.15-.24-.6-.83-1.23-.82-.67.01-.27.38.01.53.34.19.73.9.82 1.13.16.45.68 1.31 2.69.94 0 .67.01 1.3.01 1.49 0 .21-.15.46-.55.38A7.995 7.995 0 0 1 0 8c0-4.42 3.58-8 8-8Z"/></svg>
        </a>
        <button
          id="theme-toggle"
          class="icon-btn theme-toggle"
          type="button"
          aria-label="Toggle dark mode"
          aria-pressed="false"
          title="Toggle dark mode"
        >
          <span class="theme-toggle-icon" data-icon-light>☾</span>
          <span class="theme-toggle-icon" data-icon-dark>☀</span>
        </button>
      </div>
    </header>

    <div id="main-content" class="page-main" tabindex="-1">
      <slot />
    </div>

    <footer class="site-footer">
      <div class="container">
        <div class="footer-top">
          <div class="footer-brand">
            <a class="brand" href="/" aria-label="TextWizard home">
              <span class="brand-icon">✨</span>
              <span>TextWizard</span>
            </a>
            <p class="footer-tagline">
              Free, privacy-first text &amp; code tools that run entirely in your browser.
              No uploads, no accounts, no tracking — your text never leaves your device.
            </p>
            <a class="footer-github" href={repo} target="_blank" rel="noopener" aria-label="TextWizard on GitHub">
              <svg viewBox="0 0 16 16" width="24" height="24" fill="currentColor" aria-hidden="true"><path d="M8 0c4.42 0 8 3.58 8 8a8.013 8.013 0 0 1-5.45 7.59c-.4.08-.55-.17-.55-.38 0-.27.01-1.13.01-2.2 0-.75-.25-1.23-.54-1.48 1.78-.2 3.65-.88 3.65-3.95 0-.88-.31-1.59-.82-2.15.08-.2.36-1.02-.08-2.12 0 0-.67-.22-2.2.82-.64-.18-1.32-.27-2-.27-.68 0-1.36.09-2 .27-1.53-1.03-2.2-.82-2.2-.82-.44 1.1-.16 1.92-.08 2.12-.51.56-.82 1.27-.82 2.15 0 3.06 1.86 3.75 3.64 3.95-.23.2-.44.55-.51 1.07-.46.21-1.61.55-2.33-.66-.15-.24-.6-.83-1.23-.82-.67.01-.27.38.01.53.34.19.73.9.82 1.13.16.45.68 1.31 2.69.94 0 .67.01 1.3.01 1.49 0 .21-.15.46-.55.38A7.995 7.995 0 0 1 0 8c0-4.42 3.58-8 8-8Z"/></svg>
            </a>
          </div>
          <nav class="footer-col" aria-label="Tools">
            <h2 class="footer-heading">Tools</h2>
            <a href="/#tools">All tools</a>
            <a href="/tools/text-tools">Text Tools</a>
            <a href="/tools/code-data">Code &amp; Data</a>
            <a href="/tools/fancy-text">Fancy Text</a>
            <a href="/tools/qr-code">QR Code</a>
            <a href="/tools/emoji">Emoji Copy</a>
          </nav>
          <nav class="footer-col" aria-label="About">
            <h2 class="footer-heading">About</h2>
            <a href="/contact">Contact</a>
            <a href="/docs">Docs</a>
            <a href="/privacy">Privacy</a>
            <a href="/terms">Terms</a>
          </nav>
        </div>
        <div class="footer-bottom">© {year} | Created with ❤️ by <a href="https://michalferber.dev/" target="_blank" rel="noopener">Michal Ferber</a>, aka <a href="https://techguywithabeard.com/" target="_blank" rel="noopener">TechGuyWithABeard</a>.</div>
      </div>
    </footer>

    <Search />

    <script>
      // Theme toggle. The default follows the OS via CSS `prefers-color-scheme`;
      // the button sets an explicit `data-theme` override and persists the choice.
      const root = document.documentElement;
      const btn = document.getElementById('theme-toggle');
      const mq = window.matchMedia('(prefers-color-scheme: dark)');
      const isDark = () => {
        const attr = root.getAttribute('data-theme');
        if (attr === 'dark') return true;
        if (attr === 'light') return false;
        return mq.matches;
      };
      const sync = () => btn?.setAttribute('aria-pressed', String(isDark()));
      sync();
      btn?.addEventListener('click', () => {
        const next = isDark() ? 'light' : 'dark';
        root.setAttribute('data-theme', next);
        try { localStorage.setItem('tw::theme', next); } catch (_) {}
        sync();
      });
      // Keep the toggle state in step with the OS while on the system default.
      mq.addEventListener?.('change', () => {
        let saved = null;
        try { saved = localStorage.getItem('tw::theme'); } catch (_) {}
        if (saved !== 'dark' && saved !== 'light') sync();
      });
    </script>
  </body>
</html>
