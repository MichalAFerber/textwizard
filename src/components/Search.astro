---
// Client-side tool search / command palette. Opened by the header search
// button (#search-open) or the "/" and Cmd/Ctrl-K shortcuts. The searchable
// index is built from the tool catalog at build time and embedded inline.
import { tools } from '../data/tools.js';

const index = tools.map((t) => ({
  name: t.name,
  tagline: t.tagline,
  url: `/tools/${t.id}`,
  terms: [t.name, t.tagline, t.category, ...(t.keywords || [])].join(' ').toLowerCase(),
}));
---
<div id="search-modal" class="search-modal" hidden>
  <div class="search-backdrop" data-search-close></div>
  <div class="search-panel" role="dialog" aria-modal="true" aria-label="Search tools">
    <input
      id="search-input"
      class="search-input"
      type="text"
      placeholder="Search tools…"
      autocomplete="off"
      spellcheck="false"
      aria-label="Search tools"
    />
    <ul id="search-results" class="search-results" role="listbox"></ul>
    <p id="search-empty" class="search-empty" hidden>No tools match.</p>
  </div>
</div>

<script is:inline define:vars={{ index }}>
  (function () {
    var modal = document.getElementById('search-modal');
    var input = document.getElementById('search-input');
    var results = document.getElementById('search-results');
    var empty = document.getElementById('search-empty');
    var openBtn = document.getElementById('search-open');
    if (!modal || !input) return;
    var current = [];
    var active = -1;

    function esc(s) {
      return String(s).replace(/[&<>"]/g, function (c) {
        return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c];
      });
    }
    function render(q) {
      var words = q.trim().toLowerCase().split(/\s+/).filter(Boolean);
      current = index.filter(function (t) {
        return words.every(function (w) { return t.terms.indexOf(w) !== -1; });
      });
      active = current.length ? 0 : -1;
      results.innerHTML = current
        .map(function (t, i) {
          return (
            '<li class="search-item' + (i === active ? ' is-active' : '') + '" role="option" data-url="' +
            t.url + '" data-i="' + i + '">' +
            '<span class="search-item-name">' + esc(t.name) + '</span>' +
            '<span class="search-item-desc">' + esc(t.tagline) + '</span></li>'
          );
        })
        .join('');
      empty.hidden = current.length > 0;
    }
    function open() {
      modal.hidden = false;
      input.value = '';
      render('');
      requestAnimationFrame(function () { input.focus(); });
    }
    function close() { modal.hidden = true; active = -1; if (openBtn) openBtn.focus(); }
    function setActive(n) {
      if (!current.length) return;
      active = (n + current.length) % current.length;
      for (var i = 0; i < results.children.length; i++) {
        results.children[i].classList.toggle('is-active', i === active);
      }
      if (results.children[active]) results.children[active].scrollIntoView({ block: 'nearest' });
    }
    function go(i) { if (current[i]) window.location.href = current[i].url; }

    if (openBtn) openBtn.addEventListener('click', open);
    modal.addEventListener('click', function (e) {
      if (e.target.closest('[data-search-close]')) close();
    });
    input.addEventListener('input', function () { render(input.value); });
    results.addEventListener('click', function (e) {
      var li = e.target.closest('.search-item');
      if (li) go(+li.dataset.i);
    });
    input.addEventListener('keydown', function (e) {
      if (e.key === 'ArrowDown') { e.preventDefault(); setActive(active + 1); }
      else if (e.key === 'ArrowUp') { e.preventDefault(); setActive(active - 1); }
      else if (e.key === 'Enter') { e.preventDefault(); go(active); }
      else if (e.key === 'Escape') { close(); }
    });
    document.addEventListener('keydown', function (e) {
      var el = document.activeElement;
      var typing = el && (/^(input|textarea|select)$/i.test(el.tagName) || el.isContentEditable);
      if ((e.key === '/' && !typing) || ((e.metaKey || e.ctrlKey) && (e.key === 'k' || e.key === 'K'))) {
        e.preventDefault();
        open();
      } else if (e.key === 'Escape' && !modal.hidden) {
        close();
      }
    });
  })();
</script>
