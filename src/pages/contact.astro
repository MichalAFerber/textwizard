---
import Base from '../layouts/Base.astro';
const title = 'Contact — TextWizard';
const description =
  'Get in touch with the TextWizard project — send a message, or reach us on GitHub. Open source and privacy-first.';
const repo = 'https://github.com/MichalAFerber/textwizard';
---
<Base title={title} description={description}>
  <main class="container legal">
    <p><a href="/" class="legal-back">← Back to TextWizard</a></p>
    <h1>Contact</h1>
    <p class="legal-meta">Open source · privacy-first · a human replies</p>

    <p>
      Questions, bug reports, or feature ideas? Send a message below and we'll reply by email.
      Prefer to work in the open? Everything is developed on GitHub.
    </p>

    <form id="contact-form" class="contact-form" novalidate>
      <div class="form-row">
        <label class="form-field">
          <span class="form-label">Name</span>
          <input class="tw-input" type="text" name="name" required autocomplete="name" maxlength="200" />
        </label>
        <label class="form-field">
          <span class="form-label">Email</span>
          <input class="tw-input" type="email" name="email" required autocomplete="email" maxlength="320" />
        </label>
      </div>
      <label class="form-field">
        <span class="form-label">Subject <span class="form-optional">(optional)</span></span>
        <input class="tw-input" type="text" name="subject" autocomplete="off" maxlength="300" />
      </label>
      <label class="form-field">
        <span class="form-label">Message</span>
        <textarea class="tw-input contact-message" name="message" required rows="7" maxlength="5000"></textarea>
      </label>

      <!-- Honeypot: hidden from people, tempting to bots. Leave empty. -->
      <div class="hp" aria-hidden="true">
        <label>Company<input type="text" name="company" tabindex="-1" autocomplete="off" /></label>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn-primary">Send message</button>
        <p id="contact-status" class="contact-status" role="status" aria-live="polite"></p>
      </div>
      <p class="form-note">Please don't send secrets or credentials. Nothing here is stored on our servers beyond delivering your email.</p>
    </form>

    <h2>Prefer GitHub?</h2>
    <div class="info-grid">
      <a class="info-card" href={`${repo}/issues/new`} target="_blank" rel="noopener">
        <span class="info-card-title">Bugs &amp; feature requests</span>
        <span class="info-card-desc">Open an issue — public and searchable.</span>
        <span class="info-card-link">Open an issue →</span>
      </a>
      <a class="info-card" href={`${repo}/security/advisories/new`} target="_blank" rel="noopener">
        <span class="info-card-title">Security</span>
        <span class="info-card-desc">Report a vulnerability privately via a GitHub advisory.</span>
        <span class="info-card-link">Report privately →</span>
      </a>
    </div>
  </main>
</Base>

<script>
  const form = document.getElementById('contact-form');
  const statusEl = document.getElementById('contact-status');
  const btn = form?.querySelector('button[type="submit"]');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    statusEl.className = 'contact-status';
    statusEl.textContent = '';

    if (!form.name.value.trim() || !form.email.value.trim() || !form.message.value.trim()) {
      statusEl.textContent = 'Please fill in your name, email, and message.';
      statusEl.classList.add('is-err');
      return;
    }

    btn.disabled = true;
    const label = btn.textContent;
    btn.textContent = 'Sending…';
    try {
      const payload = Object.fromEntries(new FormData(form).entries());
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const data = await res.json().catch(() => ({}));
      if (res.ok && data.ok) {
        form.reset();
        statusEl.textContent = "Thanks — your message is on its way. We'll reply by email.";
        statusEl.classList.add('is-ok');
      } else {
        statusEl.textContent = data.error || 'Something went wrong. Please try again, or use GitHub below.';
        statusEl.classList.add('is-err');
      }
    } catch {
      statusEl.textContent = 'Network error. Please try again, or use GitHub below.';
      statusEl.classList.add('is-err');
    } finally {
      btn.disabled = false;
      btn.textContent = label;
    }
  });
</script>
