---
import Base from '../layouts/Base.astro';
import { tools, categories, repoUrlFor } from '../data/tools.js';

const title = 'TextWizard — Free Online Text & Code Tools';
const groups = categories
  .map((category) => ({ category, items: tools.filter((t) => t.category === category) }))
  .filter((g) => g.items.length);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'TextWizard',
  url: 'https://textwizard.us/',
  applicationCategory: 'UtilitiesApplication',
  operatingSystem: 'Any',
  browserRequirements: 'Requires a modern browser',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  description: 'Free online text and code tools that run entirely in the browser.',
};
---
<Base title={title}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)}></script>

  <main class="container">
    <section class="hero">
      <a class="hero-eyebrow" href="#tools">
        <span class="hero-eyebrow-dot"></span> {tools.length} browser-based tools · MIT open source
      </a>
      <h1 class="hero-title">Every text &amp; code tool,<br /><span class="accent">right in your browser</span></h1>
      <p class="hero-sub">
        A privacy-first collection of fast text and code utilities. Paste or drop text and
        transform it instantly — no uploads, no accounts, nothing ever leaves your device.
      </p>
      <div class="badges">
        <span class="badge"><span class="badge-dot"></span> Runs in your browser</span>
        <span class="badge"><span class="badge-dot"></span> Nothing is uploaded</span>
        <span class="badge"><span class="badge-dot"></span> Open source · MIT</span>
      </div>
    </section>

    <section id="tools" class="tool-section">
      {groups.map(({ category, items }) => (
        <>
          <h2 class="section-title">{category}</h2>
          <div class="tool-grid">
            {items.map((tool) => (
              <article class="tool-card" style={`--accent:${tool.color}`}>
                <div class="tool-card-head">
                  <span class="tool-card-icon" aria-hidden="true">{tool.icon}</span>
                  <div class="tool-card-heading">
                    <h3 class="tool-card-title"><a href={`/tools/${tool.id}`}>{tool.name}</a></h3>
                    <span class="tool-card-id">{tool.id}</span>
                  </div>
                </div>
                <p class="tool-card-desc">{tool.description}</p>
                <ul class="tool-card-tags">
                  {tool.keywords.map((k) => <li class="tag">{k}</li>)}
                </ul>
                <div class="tool-card-foot">
                  <a class="tool-card-gh" href={repoUrlFor(tool)} target="_blank" rel="noopener" aria-label={`${tool.name} source on GitHub`}>
                    <svg viewBox="0 0 16 16" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M8 0c4.42 0 8 3.58 8 8a8.013 8.013 0 0 1-5.45 7.59c-.4.08-.55-.17-.55-.38 0-.27.01-1.13.01-2.2 0-.75-.25-1.23-.54-1.48 1.78-.2 3.65-.88 3.65-3.95 0-.88-.31-1.59-.82-2.15.08-.2.36-1.02-.08-2.12 0 0-.67-.22-2.2.82-.64-.18-1.32-.27-2-.27-.68 0-1.36.09-2 .27-1.53-1.03-2.2-.82-2.2-.82-.44 1.1-.16 1.92-.08 2.12-.51.56-.82 1.27-.82 2.15 0 3.06 1.86 3.75 3.64 3.95-.23.2-.44.55-.51 1.07-.46.21-1.61.55-2.33-.66-.15-.24-.6-.83-1.23-.82-.67.01-.27.38.01.53.34.19.73.9.82 1.13.16.45.68 1.31 2.69.94 0 .67.01 1.3.01 1.49 0 .21-.15.46-.55.38A7.995 7.995 0 0 1 0 8c0-4.42 3.58-8 8-8Z"/></svg>
                  </a>
                  <span class="tool-card-cta">Open <span aria-hidden="true">→</span></span>
                </div>
              </article>
            ))}
          </div>
        </>
      ))}
    </section>
  </main>
</Base>
